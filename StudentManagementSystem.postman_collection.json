          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();\r",
                  "\r",
                  "if (response.access_token) {\r",
                  "    pm.collectionVariables.set(\r",
                  "        \"token\",\r",
                  "        response.access_token\r",
                  "    );\r",
                  "\r",
                  "    console.log(\r",
                  "        \"Token saved:\",\r",
                  "        response.access_token\r",
                  "    );\r",
